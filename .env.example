# ─── LLM API Keys ──────────────────────────────────────────────────────────────
# Primary: OpenRouter (used for company research, cover letter, resume tailoring)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Override the LLM API base URL. Useful when running through a local proxy like LiteLLM.
# Defaults to https://openrouter.ai/api/v1
# OPENROUTER_BASE_URL=http://127.0.0.1:4000/v1

# Optional: Override the primary model name. If not configured, the agent dynamically fetches 
# active free models from OpenRouter and defaults to the first available one.
# OPENROUTER_MODEL_NAME=google/gemma-2-9b-it:free

# Optional: Comma-separated list of fallback models tried by OpenRouter when the primary returns a 503.
# Defaults to dynamically fetched active free models from OpenRouter.
# OPENROUTER_FALLBACK_MODELS=google/gemma-2-9b-it:free,meta-llama/llama-3-8b-instruct:free

# Optional: Google AI Studio key (only needed if you switch spring.profiles.active=gemini)
# Get your key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Gmail (OAuth 2.0 — no password needed) ───────────────────────────────────
# Your Gmail address — used as the From: header in outreach emails.
# Auth is handled by the same OAuth flow as Google Drive (see below).
GMAIL_ADDRESS=your_email@gmail.com

# ─── Google Drive (OAuth 2.0) ─────────────────────────────────────────────────
# Paste the FULL contents of your OAuth 2.0 client secret JSON here (as one line).
# Example file: docs/examples/credentials.json.example
# Download it from: Google Cloud Console → APIs & Services → Credentials
#   → Create Credentials → OAuth client ID (Application type: Desktop app)
#   → Download JSON
# IMPORTANT: Share your target Drive folder with your Google account as Editor.
GOOGLE_CLIENT_SECRETS_JSON={"installed":{"client_id":"...","client_secret":"...","redirect_uris":["urn:ietf:wg:oauth:2.0:oob","http://localhost"]}}

# The Google Drive Folder ID where resumes will be uploaded.
# Extract from the folder URL: https://drive.google.com/drive/folders/<FOLDER_ID>
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here

# Optional: Path where OAuth tokens are stored (default: ./tokens)
GOOGLE_DRIVE_TOKENS_DIR=./tokens

# Optional: Refresh token used for CI batch mode (headless OAuth)
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# ─── CI / Batch Mode (optional) ──────────────────────────────────────────────
# Set true to run a one-shot batch using the targets file and exit.
CI_BATCH_MODE=false

# Set true to enable follow-up email drafts generation (defaults to false)
ENABLE_FOLLOWUPS=false

# Path to a targets JSON file for CI batch mode (defaults to targets.json)
TARGETS_FILE=targets.json

# ─── Production Database (optional) ──────────────────────────────────────────
# Used when spring.profiles.active=production (see application-production.yml)
DATABASE_URL=jdbc:postgresql://host:5432/dbname
DATABASE_USERNAME=your_db_username
DATABASE_PASSWORD=your_db_password

# ─── Logging (optional) ───────────────────────────────────────────────────────
# Logging level for the project's codebase (com.outreach.agent).
# Options: TRACE, DEBUG, INFO, WARN, ERROR
# APP_LOG_LEVEL=INFO