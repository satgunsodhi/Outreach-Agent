# ─── LLM API Keys ──────────────────────────────────────────────────────────────
# Primary: OpenRouter (used for company research, cover letter, resume tailoring)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Override the default model (defaults to openai/gpt-oss-120b:free)
OPENROUTER_MODEL_NAME=openai/gpt-oss-120b:free

# Optional: Google AI Studio key (only needed if you switch spring.profiles.active=gemini)
# Get your key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Gmail (OAuth 2.0 — no password needed) ───────────────────────────────────
# Your Gmail address — used as the From: header in outreach emails.
# Auth is handled by the same OAuth flow as Google Drive (see below).
GMAIL_ADDRESS=your_email@gmail.com

# ─── Google Drive (OAuth 2.0) ─────────────────────────────────────────────────
# Paste the FULL contents of your OAuth 2.0 client secret JSON here (as one line).
# Download it from: Google Cloud Console → APIs & Services → Credentials
#   → Create Credentials → OAuth client ID (Application type: Desktop app)
#   → Download JSON
# IMPORTANT: Share your target Drive folder with your Google account as Editor.
GOOGLE_SERVICE_ACCOUNT_JSON={"installed":{"client_id":"...","client_secret":"...","redirect_uris":["urn:ietf:wg:oauth:2.0:oob","http://localhost"]}}

# The Google Drive Folder ID where resumes will be uploaded.
# Extract from the folder URL: https://drive.google.com/drive/folders/<FOLDER_ID>
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here

# Optional: Path where OAuth tokens are stored (default: ./tokens)
GOOGLE_DRIVE_TOKENS_DIR=tokens